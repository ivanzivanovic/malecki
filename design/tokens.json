      "zivinarstvo":  { "value": "#B5532A", "comment": "Terakota — perad" },
      "kunicarstvo":  { "value": "#8B6F47", "comment": "Topla braon — kunići" },
      "ptice":        { "value": "#5C8A6B", "comment": "Mahovinasta zelena — egzote" },
      "glodari":      { "value": "#A89A7E", "comment": "Bež-siva — sitni glodari" }
    }
  },

  "font": {
