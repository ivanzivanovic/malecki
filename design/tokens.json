      "xl":        { "value": "1.25rem",  "comment": "20px — H4" },
      "2xl":       { "value": "1.5rem",   "comment": "24px — H3" },
      "3xl":       { "value": "1.875rem", "comment": "30px — H2 (mobile) / H3 (desktop)" },
      "4xl":       { "value": "2.25rem",  "comment": "36px — H2 (desktop)" },
      "5xl":       { "value": "3rem",     "comment": "48px — H1 (mobile)" },
      "6xl":       { "value": "3.75rem",  "comment": "60px — H1 (desktop)" },
      "7xl":       { "value": "4.5rem",   "comment": "72px — hero display (desktop, samo homepage)" }
    },
    "weight": {
      "regular":   { "value": "400" },
      "medium":    { "value": "500", "comment": "EB Garamond display weight" },
      "semibold":  { "value": "600", "comment": "Fraunces headings weight" },
      "bold":      { "value": "700" }
    },
    "lineHeight": {
      "tight":     { "value": "1.1",  "comment": "Display (H1, hero)" },
      "snug":      { "value": "1.25", "comment": "Headings (H2-H4)" },
      "normal":    { "value": "1.5",  "comment": "Body text" },
      "relaxed":   { "value": "1.75", "comment": "Long-form blog body" }
    },
    "letterSpacing": {
      "tighter":   { "value": "-0.02em", "comment": "Display headings" },
      "tight":     { "value": "-0.01em", "comment": "Headings" },
      "normal":    { "value": "0" },
      "wide":      { "value": "0.05em",  "comment": "Eyebrow uppercase tekst" },
      "widest":    { "value": "0.15em",  "comment": "Eyebrow tagline (npr. 'IZLOŽBA • SRBIJA')" }
    }
  },

  "spacing": {
    "_comment": "4px base. Tailwind default scale, ali sa nekoliko custom vrednosti za editorial razmake.",
    "px":   { "value": "1px" },
    "0":    { "value": "0" },
    "1":    { "value": "0.25rem" },
    "2":    { "value": "0.5rem" },
    "3":    { "value": "0.75rem" },
    "4":    { "value": "1rem" },
    "5":    { "value": "1.25rem" },
    "6":    { "value": "1.5rem" },
    "8":    { "value": "2rem" },
    "10":   { "value": "2.5rem" },
    "12":   { "value": "3rem" },
    "16":   { "value": "4rem" },
    "20":   { "value": "5rem" },
    "24":   { "value": "6rem" },
    "32":   { "value": "8rem", "comment": "Sekcijski razmak desktop" },
    "40":   { "value": "10rem", "comment": "Veliki sekcijski razmak (između hero-a i prvog bloka)" }
  },

  "radius": {
    "_comment": "Editorial pravac koristi malo do nimalo zaobljenih ivica. Oštri pravougaonici za CTA, suptilan radius za inputs/cards.",
    "none":  { "value": "0",       "comment": "Default za CTA dugmad, hero kartice" },
    "sm":    { "value": "2px",     "comment": "Inputs, manje kartice" },
    "md":    { "value": "4px",     "comment": "Modali, dropdowns" },
    "full":  { "value": "9999px",  "comment": "Avatar slike, badge-ovi" }
  },

  "shadow": {
    "_comment": "Editorial pravac MINIMIZUJE shadow-e. Preferiramo border + razmak. Shadow samo za overlay UI (modali, dropdowns).",
    "none":  { "value": "none" },
    "sm":    { "value": "0 1px 2px rgba(15, 14, 12, 0.04)", "comment": "Suptilan lift na hover karticama" },
    "md":    { "value": "0 4px 12px rgba(15, 14, 12, 0.08)", "comment": "Dropdown, popover" },
    "lg":    { "value": "0 12px 32px rgba(15, 14, 12, 0.12)", "comment": "Modal, lightbox" }
  },

  "breakpoint": {
    "sm":    { "value": "640px",  "comment": "Velika telefon — landscape" },
    "md":    { "value": "768px",  "comment": "Tablet" },
    "lg":    { "value": "1024px", "comment": "Mali laptop" },
    "xl":    { "value": "1280px", "comment": "Desktop default" },
    "2xl":   { "value": "1536px", "comment": "Veliki monitor" }
  },

  "container": {
    "_comment": "Maksimalne širine za content blokove. Editorial pravac voli uže kolone za čitanje.",
    "prose":     { "value": "65ch",   "comment": "Idealna širina za long-form blog body (cca 720px)" },
    "narrow":    { "value": "768px",  "comment": "Centriran sadržaj na detail stranicama" },
    "default":   { "value": "1280px", "comment": "Glavni page container" },
    "wide":      { "value": "1536px", "comment": "Hero sekcije, edge-to-edge fotografije" }
  },

  "transition": {
