{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "_meta": {
    "name": "sitnezivotinje.com — Variant C (Editorial)",
    "version": "1.0.0",
    "description": "Design tokens za editorial/magazinski vizuelni pravac. Konzumira se preko tailwind.config.ts (kao theme.extend) i preko CSS varijabli u app/globals.css.",
    "consumers": [
      "tailwind.config.ts (theme.extend.colors, fontFamily, fontSize, spacing)",
      "app/globals.css (CSS varijable za runtime override-e i theme switch)",
      "lib/seo.ts (default OG image dimenzije)"
    ]
  },

  "color": {
    "background": {
      "primary":   { "value": "#FFFFFF", "comment": "Glavna pozadina sajta" },
      "alt":       { "value": "#F4F1EC", "comment": "Alternativne sekcije (npr. featured event blok, footer)" },
      "muted":     { "value": "#FAF8F4", "comment": "Suptilan accent (npr. hover na karticama)" }
    },
    "surface": {
      "default":   { "value": "#FFFFFF", "comment": "Karte, modali, dropdown-ovi" },
      "raised":    { "value": "#FFFFFF", "comment": "Iste boje, ali sa border-bottom umesto shadow" }
    },
    "border": {
      "default":   { "value": "#E5E1D8", "comment": "Standardni divider/border" },
      "strong":    { "value": "#C9C2B3", "comment": "Naglašen border (npr. fokus stanja, aktivni filter)" },
      "subtle":    { "value": "#F0EDE6", "comment": "Vrlo lagan divider između kartica" }
    },
    "text": {
      "primary":   { "value": "#0F0E0C", "comment": "Glavni tekst, naslovi" },
      "secondary": { "value": "#3A3833", "comment": "Sekundarni tekst (lead paragraphs)" },
      "muted":     { "value": "#73706A", "comment": "Meta podaci (datumi, autori, čitanje 5 min)" },
      "inverse":   { "value": "#FFFFFF", "comment": "Tekst na tamnoj pozadini (dugmad, hero overlay)" },
      "link":      { "value": "#1F2A1A", "comment": "Linkovi u tekstu — boja brand-a, sa underline" }
    },
    "brand": {
      "primary":   { "value": "#1F2A1A", "comment": "Glavna brand boja — tamna šuma-zelena. CTA, footer pozadina, accent border." },
      "primaryHover": { "value": "#0F1A0A", "comment": "Hover stanje brand boje" },
      "primaryMuted": { "value": "#E8EBE5", "comment": "Suptilan brand-tinted background (npr. quote box)" }
    },
    "accent": {
      "default":   { "value": "#B8763E", "comment": "Topla cigla — eyebrow tekst, badge-ovi 'novo', dekorativni elementi" },
      "hover":     { "value": "#9A6132", "comment": "Hover stanje accent boje" },
      "muted":     { "value": "#E8DFC9", "comment": "Bež-zlatna pozadina za badge-ove i highlight" }
    },
    "semantic": {
      "success":   { "value": "#1F2A1A", "comment": "Success state — koristi brand boju (priznata rasa, prijava prošla)" },
      "warning":   { "value": "#B8763E", "comment": "Warning — koristi accent boju (rok prijave uskoro)" },
      "error":     { "value": "#8B2E1F", "comment": "Error — tamna cigla (validacija, prošao rok)" },
      "info":      { "value": "#3A3833", "comment": "Info — sekundarna text boja" }
    },
    "category": {
      "_comment": "Per-kategorija akcent — koristi se SAMO za suptilne markere (border-left na kartici, dot ispred eyebrow). NE za pozadine, NE za dugmad.",
